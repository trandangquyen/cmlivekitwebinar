# LAN-first internal rehearsal profile for server 192.168.1.125.
# Chosen internal domains:
# - classroom-lan.test
# - livekit-lan.test
#
# Map both names to 192.168.1.125 in internal DNS or on every client test machine:
# 192.168.1.125 classroom-lan.test livekit-lan.test
#
# If your company CA issues one SAN cert for both domains, point both TLS_* vars
# at the same mounted cert/key pair.

APP_ENV=staging
STRICT_CONFIG=true
LIVEKIT_NODE_IP=192.168.1.125

CLASSROOM_DOMAIN=classroom-lan.test
LIVEKIT_DOMAIN=livekit-lan.test
FRONTEND_ORIGIN=https://classroom-lan.test
PUBLIC_API_BASE_URL=https://classroom-lan.test

DATA_STORE=postgres
POSTGRES_PASSWORD=classroom_lan_2026_only
DATABASE_URL=postgresql://classroom:classroom_lan_2026_only@postgres:5432/classroom
DATABASE_SSL=false
DB_AUTO_MIGRATE=false

LIVEKIT_WS_URL=wss://livekit-lan.test
LIVEKIT_HTTP_URL=http://livekit:7880
LIVEKIT_API_KEY=lanclassroomkey2026
LIVEKIT_API_SECRET=lanclassroomsecret2026localonly

CLASSROOM_DEFAULT_WAITING_ROOM=true
CLASSROOM_TOKEN_TTL=3h

RECORDING_OUTPUT_MODE=local
RECORDING_LOCAL_PREFIX=/out/recordings

# Internal company certificate or internal PKI certificate paths as seen by Caddy.
CLASSROOM_TLS_CERT_FILE=/certs/classroom-lan.test.crt
CLASSROOM_TLS_KEY_FILE=/certs/classroom-lan.test.key
LIVEKIT_TLS_CERT_FILE=/certs/livekit-lan.test.crt
LIVEKIT_TLS_KEY_FILE=/certs/livekit-lan.test.key

LIVEKIT_IMAGE=livekit/livekit-server:v1.10.1
LIVEKIT_EGRESS_IMAGE=livekit/egress:v1.12.0
