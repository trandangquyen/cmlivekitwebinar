# Production profile. Store real values in the production secret manager.
API_PORT=4300
FRONTEND_ORIGIN=https://classroom.example.com
PUBLIC_API_BASE_URL=https://classroom.example.com

DATA_STORE=postgres
DATABASE_URL=postgresql://classroom:replace-me@classroom-postgres:5432/classroom
DATABASE_SSL=true
DB_AUTO_MIGRATE=false

LIVEKIT_WS_URL=wss://livekit.example.com
LIVEKIT_HTTP_URL=https://livekit.example.com
LIVEKIT_API_KEY=replace-me
LIVEKIT_API_SECRET=replace-me

CLASSROOM_DEFAULT_WAITING_ROOM=true
CLASSROOM_TOKEN_TTL=2h

RECORDING_OUTPUT_MODE=s3
S3_ACCESS_KEY=replace-me
S3_SECRET=replace-me
S3_BUCKET=classroom-recordings-production
S3_REGION=us-east-1
S3_ENDPOINT=https://minio.example.com
S3_FORCE_PATH_STYLE=true

LIVEKIT_IMAGE=livekit/livekit-server:v1.10.1
LIVEKIT_EGRESS_IMAGE=livekit/egress:v1.12.0
