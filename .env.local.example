# Local development profile.
APP_ENV=local
STRICT_CONFIG=false
API_PORT=4300
FRONTEND_ORIGIN=http://localhost:5173
PUBLIC_API_BASE_URL=http://localhost:4300

DATA_STORE=memory
DB_AUTO_MIGRATE=false

LIVEKIT_WS_URL=ws://localhost:7880
LIVEKIT_HTTP_URL=http://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

CLASSROOM_DEFAULT_WAITING_ROOM=true
CLASSROOM_TOKEN_TTL=3h

RECORDING_OUTPUT_MODE=local
RECORDING_LOCAL_PREFIX=/out/recordings

LIVEKIT_IMAGE=livekit/livekit-server:v1.10.1
LIVEKIT_EGRESS_IMAGE=livekit/egress:v1.12.0
