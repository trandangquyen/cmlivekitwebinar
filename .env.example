# API
API_PORT=4300
FRONTEND_ORIGIN=http://localhost:5173
PUBLIC_API_BASE_URL=http://localhost:4300

# LiveKit self-hosted server
LIVEKIT_WS_URL=ws://localhost:7880
LIVEKIT_HTTP_URL=http://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_WEBHOOK_VERIFY=true
# Optional for Docker Desktop media/recording. scripts/start-stack.ps1 auto-detects it.
LIVEKIT_NODE_IP=

# Optional classroom defaults
CLASSROOM_DEFAULT_WAITING_ROOM=true
CLASSROOM_TOKEN_TTL=3h

# Persistence
# DATA_STORE=memory keeps the local dev API dependency-free.
# Use DATA_STORE=postgres for staging/full Docker persistence.
DATA_STORE=memory
DATABASE_URL=postgresql://classroom:classroom_dev@localhost:5432/classroom
DATABASE_SSL=false
DB_AUTO_MIGRATE=false

# Recording through self-hosted LiveKit Egress.
# For local egress, mount ./recordings into the egress container.
RECORDING_OUTPUT_MODE=local
RECORDING_LOCAL_PREFIX=/out/recordings

# S3-compatible storage, optional. MinIO also works with these fields.
S3_ACCESS_KEY=
S3_SECRET=
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=true
